PORT=3004
NODE_ENV=development

# Redis Connection (for presence and pub/sub) - REQUIRED for horizontal scaling
# Get this from Upstash Redis Dashboard: https://console.upstash.com/redis
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_UPSTASH_HOST:6379
REDIS_HOST=YOUR_UPSTASH_HOST
REDIS_PASSWORD=YOUR_UPSTASH_PASSWORD

# JWT Secret (for authenticating WebSocket connections) - MUST match auth-service
JWT_SECRET=your_jwt_secret_key

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Pub/Sub Channels (customize if needed)
REDIS_CHAT_CHANNEL=chat.message
REDIS_GROUP_CHANNEL=chat.group.message

# Production settings
# NODE_ENV=production
# PORT=80
# FRONTEND_URL=https://your-frontend-domain.com