# Environment Variables Template for Chat Service
# Copy this file to .env and fill in your actual values

PORT=3003
NODE_ENV=development

# MongoDB Connection (Replace with your cloud MongoDB URL)
MONGO_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/?appName=YourApp

# Redis Connection for pub/sub
REDIS_URL=redis://your-redis-host:6379
# Or for Upstash Redis:
# REDIS_URL=redis://default:your-password@your-host.upstash.io:6379

# JWT Secret (should match auth service)
JWT_SECRET=your-super-secret-jwt-key-here